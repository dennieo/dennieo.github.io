# Скопируйте в .env и заполните. Файл .env НЕ коммитится.

# Ключи Binance (для mode=live) или testnet.binance.vision (для mode=testnet).
# На ключе включайте ТОЛЬКО "Enable Reading" и "Enable Spot Trading".
# НИКОГДА не включайте "Enable Withdrawals".
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram-уведомления (опционально, telegram.enabled: true в config.yaml)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
